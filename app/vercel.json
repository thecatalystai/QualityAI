{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    },
    {
      "source": "/(.*).json",
      "headers": [{ "key": "Content-Type", "value": "application/json; charset=utf-8" }]
    }
  ]
}
