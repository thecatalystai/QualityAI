{
    "id": "itp",
    "version": "1.0",

    "fields": [
        {
            "name": "work_title",
            "label": "Work Title",
            "type": "text"
        },
        {
            "name": "discipline",
            "label": "Discipline",
            "type": "dropdown",
            "options": ["Civil", "Mechanical", "Electrical"]
        },
        {
            "name": "activity",
            "label": "Construction Activity",
            "type": "text"
        },        
        {
            "name": "stages",
            "label": "Stages",
            "type": "multiselect",
            "options": ["Document Review", "Factory Inspection", "Material Receiving", "Survey", "Preparation", "Construction", "Installation", "Testing", "Commissioning"]
        },
        {
            "name": "stakeholder",
            "label": "Stakeholder",
            "type": "multiselect",
            "options": ["Client", "Contractor", "Consultant", "QA/QC - Quality Control", "Third Party Testing Service", "HSE - Health & Safety", "Vendor", "PMO", "Operator", "Developer", Owner", "Sub Contractor", "Developer"]
        },        
        {
            "name": "remarks",
            "label": "Remarks",
            "type": "textarea"
        }
    ],

    "template": "Prepare Inspection and Testing Plan for {{work_title}} in {{discipline}} discipline.\n\nStages: {{stages}}.\n\nOutput strictly in JSON under ITP_JSON."
}
